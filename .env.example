# Perfil exclusivo da v4.
# Não use o mesmo profile de outras versões abertas ao mesmo tempo.
WA_PROFILE_DIR=profile_whatsapp_v4

# Playwright roda em segundo plano (sem janela). Use visible=true no painel só para QR Code.
WA_HEADLESS=true

# Tempo máximo para aguardar carregamento do WhatsApp Web.
WA_READY_TIMEOUT=180

# Navegador real para Playwright (evita bloqueio do WhatsApp Web).
# Windows: msedge | chrome | none (Chromium embutido — não recomendado)
WA_BROWSER_CHANNEL=msedge

# Pasta onde as mensagens serão gravadas.
WA_EXPORT_DIR=exports

# Pasta onde o estado/deduplicação será gravado.
WA_STATE_DIR=state

# MongoDB — conversas lidas do WhatsApp (obrigatório para gravar/recuperar conversas).
# Suba com: docker compose up -d   ou   .\rodar_mongo.bat
MONGODB_URI=mongodb://localhost:27020/whatsapp
MONGODB_DB=whatsapp
MONGODB_CONVERSATIONS_COLLECTION=conversations
MONGODB_MESSAGES_COLLECTION=conversation_messages

# PostgreSQL + pgvector — busca semântica (docker compose up -d postgres)
SEMANTIC_DB_URI=postgresql://whatsapp:whatsapp@localhost:5434/whatsapp
SEMANTIC_EMBEDDING_PROVIDER=fastembed
SEMANTIC_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
SEMANTIC_EMBEDDING_DIM=384
# Alternativas: ollama (OLLAMA_URL), openai (OPENAI_API_KEY), hash (testes)
