{
  "interval_seconds": 60,
  "scrolls_per_target": 8,
  "delay_between_scrolls": 1.0,
  "delay_between_targets": 2.0,
  "append_only_new_messages": true,
  "targets": [
    {
      "id": "numero_exemplo",
      "type": "phone",
      "phone": "5562999999999",
      "enabled": true,
      "send": {
        "enabled": true,
        "message": "Mensagem para o número."
      }
    },
    {
      "id": "grupo_exemplo",
      "type": "group",
      "name": "Nome exato do grupo no WhatsApp",
      "enabled": true,
      "send": {
        "enabled": true,
        "message": "Mensagem para o grupo."
      }
    }
  ]
}
